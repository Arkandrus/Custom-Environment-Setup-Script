{
    "workbench.editor.restoreViewState": true,
    "files.hotExit": "onExitAndWindowClose",
    "workbench.editor.showTabs": "multiple",
    "workbench.editor.tabSizing": "shrink",
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.value": 12,
    "workbench.editor.limit.perEditorGroup": true,
    "workbench.tree.indent": 12,
    "workbench.list.smoothScrolling": true,
    "workbench.startupEditor": "none",
    "window.commandCenter": false,
    "window.titleBarStyle": "custom",
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    // ====================================================================
    // Explorer
    // ====================================================================
    "explorer.openEditors.visible": 1,
    "explorer.compactFolders": false,
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.cs": "${capture}.designer.cs, ${capture}.resx",
        "*.csproj": "*.csproj.user, packages.lock.json",
        ".editorconfig": ".gitignore, .gitattributes, .editorconfig"
    },
    "outline.showVariables": false,
    "outline.problems.enabled": true,
    // ====================================================================
    // Editor
    // ====================================================================
    "editor.minimap.enabled": false,
    "editor.fontSize": 14,
    "editor.lineHeight": 1.5,
    "editor.cursorBlinking": "smooth",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.smoothScrolling": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.stickyScroll.enabled": true,
    "editor.stickyScroll.maxLineCount": 5,
    "editor.renderWhitespace": "boundary",
    "editor.rulers": [
        120
    ],
    "editor.wordWrap": "off",
    "editor.linkedEditing": true,
    "editor.inlineSuggest.enabled": true,
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.organizeImports": "explicit"
    },
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    // ====================================================================
    // Terminal
    // ====================================================================
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.smoothScrolling": true,
    // ====================================================================
    // C# / .NET
    // ====================================================================
    "dotnet.defaultSolution": "disable",
    "dotnet.codeLens.enableReferencesCodeLens": true,
    "dotnet.codeLens.enableTestsCodeLens": true,
    "dotnet.inlayHints.enableInlayHintsForParameters": true,
    "dotnet.inlayHints.enableInlayHintsForTypes": false,
    "csharp.semanticHighlighting.enabled": true,
    "omnisharp.useModernNet": true,
    // ====================================================================
    // Testing
    // ====================================================================
    "testing.automaticallyOpenPeekView": "never",
    "testing.followRunningTest": true,
    "testing.openTesting": "neverOpen",
    "testing.defaultGutterClickAction": "run",
    // ====================================================================
    // Git (manual fetch)
    // ====================================================================
    "git.autofetch": false,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "git.openRepositoryInParentFolders": "always",
    "scm.diffDecorations": "all",
    // ====================================================================
    // GitLens (free-tier optimized)
    // ====================================================================
    "gitlens.plusFeatures.enabled": false,
    "gitlens.codeLens.enabled": true,
    "gitlens.currentLine.enabled": true,
    "gitlens.currentLine.pullRequests.enabled": false,
    "gitlens.hovers.currentLine.over": "line",
    "gitlens.statusBar.enabled": true,
    "gitlens.views.repositories.files.layout": "tree",
    "gitlens.views.scm.grouped.views": {
        "commits": true,
        "branches": true,
        "remotes": true,
        "stashes": true,
        "tags": true,
        "worktrees": true,
        "contributors": true,
        "fileHistory": true,
        "repositories": true,
        "searchAndCompare": true,
        "launchpad": false
    },
    // ====================================================================
    // Spell checker
    // ====================================================================
    "cSpell.enabled": true,
    "cSpell.diagnosticLevel": "Hint",
    "cSpell.checkOnlyEnabledFileTypes": true,
    "cSpell.enabledFileTypes": {
        "csharp": true,
        "markdown": true,
        "plaintext": true,
        "powershell": true,
        "json": false,
        "jsonc": false
    },
    // ====================================================================
    // TODO highlight (4-keyword scheme)
    // ====================================================================
    "todohighlight.isEnable": true,
    "todohighlight.keywords": [
        {
            "text": "TODO:",
            "color": "#fff",
            "backgroundColor": "#ffbd2a"
        },
        {
            "text": "FIXME:",
            "color": "#fff",
            "backgroundColor": "#f06292"
        },
        {
            "text": "HACK:",
            "color": "#fff",
            "backgroundColor": "#7e57c2"
        },
        {
            "text": "NOTE:",
            "color": "#3c3c3c",
            "backgroundColor": "lightblue"
        }
    ],
    // ====================================================================
    // Vim
    // ====================================================================
    "vim.useCtrlKeys": true,
    "vim.useSystemClipboard": true,
    "vim.hlsearch": true,
    "vim.incsearch": true,
    "vim.smartRelativeLine": true,
    "vim.surround": true,
    "vim.highlightedyank.enable": true,
    "vim.searchHighlightColor": "#f6ff0080",
    "vim.searchHighlightTextColor": "#fff",
    "vim.leader": "<space>",
    "vim.handleKeys": {
        "<C-a>": false,
        "<C-f>": false,
        "<C-c>": false,
        "<C-v>": false,
        "<C-z>": false,
        "<C-p>": false
    },
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            // Clear search highlights with Esc
            "before": [
                "<Esc>"
            ],
            "when": [
                "editorFocus"
            ],
            "commands": [
                ":nohl"
            ],
            "silent": true
        },
        {
            "before": [
                "+"
            ],
            "after": [
                "1"
            ]
        },
        {
            "before": [
                "ě"
            ],
            "after": [
                "2"
            ]
        },
        {
            "before": [
                "š"
            ],
            "after": [
                "3"
            ]
        },
        {
            "before": [
                "č"
            ],
            "after": [
                "4"
            ]
        },
        {
            "before": [
                "ř"
            ],
            "after": [
                "5"
            ]
        },
        {
            "before": [
                "ž"
            ],
            "after": [
                "6"
            ]
        },
        {
            "before": [
                "ý"
            ],
            "after": [
                "7"
            ]
        },
        {
            "before": [
                "á"
            ],
            "after": [
                "8"
            ]
        },
        {
            "before": [
                "í"
            ],
            "after": [
                "9"
            ]
        },
        {
            "before": [
                "é"
            ],
            "after": [
                "0"
            ]
        },
        {
            // Visual block mode (replaces lost <C-v>)
            // Ctrl+Q is a bare-letter combo on Czech QWERTZ, works fine.
            "before": [
                "<C-q>"
            ],
            "commands": [
                "extension.vim_ctrl+v"
            ]
        },
        {
            "before": [
                "ů"
            ],
            "after": [
                "^"
            ]
        },
        {
            "before": [
                "§"
            ],
            "after": [
                "$"
            ]
        },
        {
            "before": [
                "("
            ],
            "after": [
                "{"
            ]
        },
        {
            "before": [
                ")"
            ],
            "after": [
                "}"
            ]
        },
        // ---------- Leader (space) bindings — handled by VIM extension, safe in terminal ----------
        {
            "before": [
                "<leader>",
                "j"
            ],
            "commands": [
                "workbench.action.togglePanel"
            ]
        },
        {
            "before": [
                "<leader>",
                "b",
                "o"
            ],
            "commands": [
                "workbench.action.closeOtherEditors"
            ]
        },
        {
            "before": [
                "<leader>",
                "e"
            ],
            "commands": [
                "workbench.action.toggleSidebarVisibility",
                "workbench.files.action.focusFilesExplorer"
            ]
        },
        {
            "before": [
                "<leader>",
                "w"
            ],
            "commands": [
                "workbench.action.files.save"
            ]
        },
        {
            "before": [
                "<leader>",
                "g",
                "g"
            ],
            "commands": [
                "workbench.view.scm",
                "workbench.scm.focus"
            ]
        },
        {
            "before": [
                "<leader>",
                "g",
                "t"
            ],
            "commands": [
                "workbench.action.terminal.new"
            ]
        },
        {
            "before": [
                "<leader>",
                "q"
            ],
            "commands": [
                "workbench.action.files.save",
                "workbench.action.closeActiveEditor"
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "a"
            ],
            "commands": [
                "editor.action.codeAction"
            ]
        },
        {
            "before": [
                "<leader>",
                "r",
                "n"
            ],
            "commands": [
                "editor.action.rename"
            ],
            "when": [
                "editorHasRenameProvider",
                "!editorReadonly"
            ]
        },
        {
            "before": [
                "<leader>",
                "g",
                "s"
            ],
            "commands": [
                "workbench.action.gotoSymbol"
            ]
        },
        {
            "before": [
                "<leader>",
                "f",
                "f"
            ],
            "commands": [
                "workbench.action.quickOpen"
            ]
        },
        {
            "before": [
                "<leader>",
                "g",
                "d"
            ],
            "commands": [
                "editor.action.revealDefinition"
            ]
        },
        {
            "before": [
                "<leader>",
                "g",
                "r"
            ],
            "commands": [
                "editor.action.goToReferences"
            ]
        },
        {
            "before": [
                "<leader>",
                "g",
                "i"
            ],
            "commands": [
                "editor.action.goToImplementation"
            ]
        },
        {
            "before": [
                "<leader>",
                "d",
                "n"
            ],
            "commands": [
                "editor.action.marker.next"
            ]
        },
        {
            "before": [
                "<leader>",
                "d",
                "p"
            ],
            "commands": [
                "editor.action.marker.prev"
            ]
        },
        {
            "before": [
                "<leader>",
                "s"
            ],
            "commands": [
                "workbench.action.splitEditorRight"
            ]
        },
        {
            "before": [
                "<leader>",
                "v"
            ],
            "commands": [
                "workbench.action.splitEditorDown"
            ]
        },
        {
            "before": [
                "<leader>",
                "a"
            ],
            "commands": [
                "vscode-harpoon.addEditor"
            ]
        },
        {
            "before": [
                "<leader>",
                "h"
            ],
            "commands": [
                "vscode-harpoon.editEditors"
            ]
        },
        {
            "before": [
                "<leader>",
                "p"
            ],
            "commands": [
                "vscode-harpoon.editorQuickPick"
            ]
        },
        {
            "before": [
                "<leader>",
                "+"
            ],
            "commands": [
                "vscode-harpoon.gotoEditor1"
            ]
        },
        {
            "before": [
                "<leader>",
                "ě"
            ],
            "commands": [
                "vscode-harpoon.gotoEditor2"
            ]
        },
        {
            "before": [
                "<leader>",
                "š"
            ],
            "commands": [
                "vscode-harpoon.gotoEditor3"
            ]
        },
        {
            "before": [
                "<leader>",
                "č"
            ],
            "commands": [
                "vscode-harpoon.gotoEditor4"
            ]
        },
        {
            "before": [
                "<leader>",
                "ř"
            ],
            "commands": [
                "vscode-harpoon.gotoEditor5"
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "c"
            ],
            "commands": [
                "workbench.action.toggleAuxiliaryBar"
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "f"
            ],
            "commands": [
                "workbench.action.chat.openInSidebar"
            ]
        },
        {
            "before": [
                "<leader>",
                "t",
                "t"
            ],
            "commands": [
                "workbench.view.testing.focus"
            ]
        },
        {
            "before": [
                "<leader>",
                "t",
                "r"
            ],
            "commands": [
                "testing.runAll"
            ]
        },
        {
            "before": [
                "<leader>",
                "t",
                "f"
            ],
            "commands": [
                "testing.runCurrentFile"
            ]
        },
        {
            "before": [
                "<leader>",
                "z"
            ],
            "commands": [
                "workbench.action.toggleZenMode"
            ]
        },
        {
            "before": [
                "<leader>",
                "o"
            ],
            "commands": [
                "outline.focus"
            ]
        },
        {
            "before": [
                "<leader>",
                "u",
                "h"
            ],
            "commands": [
                "workbench.action.increaseViewWidth"
            ]
        },
        {
            "before": [
                "<leader>",
                "u",
                "H"
            ],
            "commands": [
                "workbench.action.decreaseViewWidth"
            ]
        },
        {
            "before": [
                "<leader>",
                "u",
                "v"
            ],
            "commands": [
                "workbench.action.increaseViewHeight"
            ]
        },
        {
            "before": [
                "<leader>",
                "u",
                "V"
            ],
            "commands": [
                "workbench.action.decreaseViewHeight"
            ]
        },
        {
            "before": [
                "<leader>",
                "u",
                "m"
            ],
            "commands": [
                "workbench.action.maximizeEditor"
            ]
        },
        {
            "before": [
                "<leader>",
                "f",
                "o"
            ],
            "commands": [
                "workbench.action.files.openFolder"
            ]
        },
        {
            "before": [
                "<leader>",
                "f",
                "r"
            ],
            "commands": [
                "workbench.action.openRecent"
            ]
        },
        {
            "before": [
                "<leader>",
                "n",
                "b"
            ],
            "commands": [
                "csdevkit.buildSolution"
            ],
            "when": [
                "solutionOpened"
            ]
        },
        {
            "before": [
                "<leader>",
                "n",
                "r"
            ],
            "commands": [
                "csdevkit.rebuildSolution"
            ],
            "when": [
                "solutionOpened"
            ]
        },
        {
            "before": [
                "<leader>",
                "n",
                "s"
            ],
            "commands": [
                "csdevkit.openSolution"
            ]
        }
    ],
    "vim.visualModeKeyBindings": [
        {
            // Paste in visual mode without clobbering register
            "before": [
                "p"
            ],
            "after": [
                "P"
            ]
        },
        {
            "before": [
                "ů"
            ],
            "after": [
                "^"
            ]
        },
        {
            "before": [
                "§"
            ],
            "after": [
                "$"
            ]
        }
    ],
    "vim.operatorPendingModeKeyBindings": [
        {
            "before": [
                "ů"
            ],
            "after": [
                "^"
            ]
        },
        {
            "before": [
                "§"
            ],
            "after": [
                "$"
            ]
        }
    ],
    // Pin Vim to its own extension host process (reduces input lag)
    "extensions.experimental.affinity": {
        "vscodevim.vim": 1
    },
    // ====================================================================
    // Third-party
    // ====================================================================
    "latex-workshop.latex.autoBuild.run": "never",
    "latex-workshop.latex.recipe.default": "lastUsed",
    "lean4.alwaysAskBeforeInstallingLeanVersions": false,
    "claudeCode.preferredLocation": "panel",
    // ====================================================================
    // Misc
    // ====================================================================
    "telemetry.telemetryLevel": "off",
    "update.showReleaseNotes": false,
    "extensions.ignoreRecommendations": true,
    "security.workspace.trust.untrustedFiles": "open",
    "testing.automaticallyOpenTestResults": "neverOpen",
    "diffEditor.ignoreTrimWhitespace": false,
    "chat.viewSessions.orientation": "stacked",
    "window.menuBarVisibility": "compact",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.colorTheme": "Visual Studio Dark Theme",
    "material-icon-theme.folders.theme": "classic",
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "vssolution.solutionExplorerIcons": "current-theme"
}
